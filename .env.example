APP_URL=http://localhost:3000
STORAGE_BACKEND=file
CRON_SECRET=replace-with-a-long-random-string
IMPORT_RUNTIME_BUDGET_MS=225000
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-a-strong-password
# Neon pooled connection string.
# In Vercel, install the Neon Marketplace integration and let Vercel inject this automatically.
DATABASE_URL=postgresql://user:password@ep-example-pooler.eu-central-1.aws.neon.tech/neondb?sslmode=require
TED_API_BASE_URL=https://api.ted.europa.eu
TED_QUERY=((BT-21-Procedure ~ "software" OR BT-21-Procedure ~ "cloud" OR BT-21-Procedure ~ "cyber" OR BT-21-Procedure ~ "data") AND notice-type IN (cn-standard, pin-only))
TED_PAGE_SIZE=50
DIGEST_FROM=noreply@example.com
DIGEST_TO=eric.leconte@gmail.com
MAILGUN_API_KEY=key-example
MAILGUN_DOMAIN=mg.example.com
MAILGUN_FROM=Tender Hunter <mailgun@mg.example.com>
# Use https://api.eu.mailgun.net for EU-region Mailgun accounts.
MAILGUN_API_BASE_URL=https://api.mailgun.net
